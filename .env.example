# Ambil dari Discord Developer Portal
DISCORD_TOKEN=ISI_TOKEN_BOT
CLIENT_ID=ISI_APPLICATION_CLIENT_ID
GUILD_ID=ISI_SERVER_ID

# Role admin yang boleh konfirmasi pembayaran
ADMIN_ROLE_ID=ISI_ROLE_ADMIN_ID

# Channel untuk menerima laporan bukti bayar dari user
ADMIN_LOG_CHANNEL_ID=ISI_CHANNEL_LOG_ADMIN_ID

# Opsional: kategori untuk channel upload bukti pembayaran
CATEGORY_PROOF_ID=

# Opsional: kategori untuk channel khusus pembeli yang sudah bayar
CATEGORY_PAID_ID=

# File gambar QRIS. Ganti assets/qris.png dengan QRIS toko kamu.
QRIS_IMAGE_PATH=./assets/qris.png

# Nama toko yang muncul di embed pembuka
STORE_NAME=Toko Akun Digital
